# physiolog 환경변수 예시
# 실제 값은 .env.local 파일을 만들어서 채워주세요 (.env.local은 gitignore 됨)

# --- Supabase (필수) ---
# https://supabase.com/dashboard 프로젝트 → Settings → API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...

# 회원가입 이메일 confirm 링크가 가리킬 사이트 URL
# 로컬 dev면 http://localhost:3000, 배포 환경이면 실제 도메인
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Anthropic Claude API (선택) ---
# 환자 ICF AI 평가 기능(/patients/[id]/icf/new)에서만 사용
# 없으면 ICF 분석 호출 시 503 응답 — 다른 기능은 정상 작동
# 키 발급: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...
